NEXT_PUBLIC_API_URL=http://localhost:8002
BACKEND_URL=http://localhost:8002

# Must match root .env AUTH_INTERNAL_SERVICE_KEY and JWT_SECRET
AUTH_INTERNAL_SERVICE_KEY=generate-a-long-random-secret
JWT_SECRET=change-me-in-production
JWT_COOKIE_NAME=pg_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Gmail SMTP for OTP emails (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=PlayGraphAI <your@gmail.com>
