# ─── Backend ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nextplay:nextplay@localhost:5432/nextplay
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nextplay-assets
MINIO_SECURE=false

# ─── Kafka (Redpanda) ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── Cognee (required — intelligence layer) ────────────
COGNEE_DATASET=nextplay_ai
LLM_API_KEY=your_openai_api_key
# Optional: use Ollama locally
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text:latest
# EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
# EMBEDDING_DIMENSIONS=768

DATA_ROOT_DIRECTORY=./.cognee_data
SYSTEM_ROOT_DIRECTORY=./.cognee_system

# ─── LLM (Qwen — coach chat) ───────────────────────────
# OpenAI-compatible endpoint (DashScope, etc.)
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# ─── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
