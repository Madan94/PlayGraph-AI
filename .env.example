# ─── Backend ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nextplay:nextplay@localhost:5432/nextplay
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_COOKIE_NAME=pg_session

# OTP auth (shared with Next.js BFF — use same value in frontend/.env.local)
AUTH_INTERNAL_SERVICE_KEY=generate-a-long-random-secret
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ─── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nextplay-assets
MINIO_SECURE=false

# ─── Kafka (Redpanda) ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Workers POST ingest jobs here (host dev: :8002; Docker full stack overrides to http://backend:8000)
PLAYGRAPH_API_URL=http://localhost:8002

# ─── Cognee (required — intelligence layer) ────────────
# Mode: embedded (local SDK) or cloud (managed Cognee Cloud tenant)
COGNEE_MODE=cloud
COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your_cognee_cloud_api_key
COGNEE_DATASET=nextplay_ai

# Embedded mode only (ignore when COGNEE_MODE=cloud):
COGNEE_SKIP_CONNECTION_TEST=false
ENABLE_BACKEND_ACCESS_CONTROL=false
# Disable on Windows — Ladybug subprocess mode can kill the parent uvicorn process.
GRAPH_DATABASE_SUBPROCESS_ENABLED=false
VECTOR_DB_SUBPROCESS_ENABLED=false

# Embedded mode only — OpenRouter (recommended) — https://openrouter.ai/keys
# Cloud handles graph extraction internally; these are not used when COGNEE_MODE=cloud.
LLM_PROVIDER=custom
LLM_MODEL=openrouter/openai/gpt-4o-mini
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_ENDPOINT=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=your_openrouter_api_key
EMBEDDING_DIMENSIONS=1536

# Alternative: OpenAI directly
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-4o-mini
# LLM_API_KEY=your_openai_api_key
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_API_KEY=your_openai_api_key

# Alternative: Ollama locally (no API key)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text:latest
# EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
# EMBEDDING_DIMENSIONS=768

# Embedded mode only — use absolute paths on Windows so PlayGraph + Cognee CLI share folders:
# DATA_ROOT_DIRECTORY=D:\PlayGraph-AI\.cognee_data
# SYSTEM_ROOT_DIRECTORY=D:\PlayGraph-AI\.cognee_system
DATA_ROOT_DIRECTORY=./.cognee_data
SYSTEM_ROOT_DIRECTORY=./.cognee_system

# ─── Coach chat (OpenAI-compatible API) ────────────────
QWEN_API_URL=https://openrouter.ai/api/v1
QWEN_API_KEY=your_openrouter_api_key
QWEN_MODEL=openai/gpt-4o

# ─── Video vision analysis (OpenRouter) ────────────────
VISION_API_URL=https://openrouter.ai/api/v1
VISION_API_KEY=your_openrouter_api_key
VISION_MODEL=openai/gpt-4o
VISION_SYNTH_MODEL=openai/gpt-4o-mini
VISION_MAX_FRAMES=10

# ─── Audio transcription (OpenRouter Whisper) ─────────
AUDIO_API_URL=https://openrouter.ai/api/v1
AUDIO_API_KEY=your_openrouter_api_key
AUDIO_TRANSCRIBE_MODEL=openai/whisper-1
AUDIO_MODEL=openai/gpt-4o-mini

# ─── PlayGraph app ports (avoid Cognee CLI: 3000 / 8000 / 8001) ─
BACKEND_PORT=8002
FRONTEND_PORT=3002
CORS_ORIGINS=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:8002

# ─── Frontend ──────────────────────────────────────────
