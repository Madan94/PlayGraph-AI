# Base URL of the NextPlayAI backend (FastAPI). Must be reachable from the device/emulator
# running the app — "localhost" only works for the iOS Simulator.
#   Android emulator  -> http://10.0.2.2:8000
#   Physical device   -> http://<your-computer-LAN-IP>:8000
# If unset, src/config/env.ts guesses a sensible default from the platform / Metro host.
EXPO_PUBLIC_API_URL=http://localhost:8000
